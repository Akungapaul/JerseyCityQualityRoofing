# Cloudflare Turnstile (spam protection)
# Get keys from: Cloudflare Dashboard -> Turnstile -> Add Widget
# Test keys for development:
#   Site key: 1x00000000000000000000AA (always passes)
#   Secret key: 1x0000000000000000000000000000000AA (always passes)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# Resend (email delivery)
# Get key from: Resend Dashboard -> API Keys -> Create API Key
RESEND_API_KEY=re_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Lead notification recipient
NOTIFICATION_EMAIL=info@jerseycityqualityroofing.com
